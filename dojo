# WRITE
# ═══════════════════════════════════════════════════════════════════════

cmd_new() {
  local date_str human_date human_time filepath slug prompt key mood time_of_day
  date_str=$(date +%Y-%m-%d)
  human_date=$(date +"%A, %B %d, %Y")
  human_time=$(date +"%H:%M")
  slug="${date_str}_$(date +%H%M)"
  filepath="${ENTRIES_DIR}/${slug}.md"
  local c=1
  while [[ -f "${filepath}" ]]; do
    filepath="${ENTRIES_DIR}/${slug}_${c}.md"; c=$((c + 1))
  done

  # Detect time of day for prompt pool
  time_of_day=$(detect_time_of_day)

  # ── Mood selection ──────────────────────────────────────────────────
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  $(t mood_title)"
  echo ""
  mood_menu
  echo ""
  echo -n "  > "
  stty echo 2>/dev/null || true
  read -n 1 -r key 2>/dev/null || key="8"
  echo ""
  mood=$(mood_key_for "${key}")

  # ── Energy ─────────────────────────────────────────────────────────
  local energy
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  ᗢ"
  echo ""
  echo "  $(t energy_title)"
  echo "  $(t energy_hint)"
  echo ""
  while true; do
    echo -n "  > "
    stty echo 2>/dev/null || true
    read -r energy 2>/dev/null || energy="5"
    [[ "${energy}" == "q" || "${energy}" == "quit" ]] && { quit_cleanup; exit 0; }
    [[ -z "${energy}" ]] && energy="5"
    if [[ "${energy}" =~ ^[0-9]+$ ]] && [ "${energy}" -ge 1 ] && [ "${energy}" -le 10 ]; then
      break
    fi
    echo "  1–10 please"
  done

  # Start with a time-of-day prompt (mood still saved for frontmatter)
  prompt=$(pick_time_prompt "${time_of_day}")

  # ── Fetch recent tags for suggestions ──────────────────────────────
  local recent_tags unresolved resolved_pairs
  recent_tags=$("${ENGINE}" weaknesses 2>/dev/null | head -5 | cut -d'|' -f2 | tr '\n' ',' | sed 's/,$//; s/,/, /g' || true)
  # Get unresolved weaknesses count
  local unresolved_count
  unresolved_count=$("${ENGINE}" weaknesses --json 2>/dev/null | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")
  # Get recently linked pairs
  resolved_pairs=$(sqlite3 "${DB}" "SELECT m1.text || ' → ' || m2.text FROM bridges b JOIN markers m1 ON b.patch_id = m1.id JOIN markers m2 ON b.weakness_id = m2.id ORDER BY b.id DESC LIMIT 3" 2>/dev/null || true)

  # ── Prompt screen — show it, let user roll or accept ───────────────
  while true; do
    stty sane 2>/dev/null || true
    stty echo 2>/dev/null || true
    clear
    echo ""
    echo "  ᗢ"
    echo ""
    echo "  ${DIM}${human_date}  ${human_time}  ·  ${DIM}$(_t tod_${time_of_day})${RESET}"
    echo ""
    echo "  ${prompt}"
    echo ""
    echo "  ${DIM}$(t tag_title)${RESET}"
    echo "  ${DIM}struggle: @weakness[thing]     solution: @patch[solution]${RESET}"
    # Show unresolved weaknesses as suggestions
    if [[ -n "${recent_tags}" ]]; then
      echo ""
      echo "  ${DIM}Still open: ${recent_tags}${RESET}"
    fi
    # Show recent solutions that worked
    if [[ -n "${resolved_pairs}" ]]; then
      echo "  ${DIM}Solved:${RESET}"
      while IFS= read -r pair; do
        [[ -n "${pair}" ]] && echo "  ${DIM}  ${pair}${RESET}"
      done <<< "${resolved_pairs}"
    fi
    echo ""
    echo "  $(t prompt_write_hint)    $(t prompt_roll)    $(t prompt_mood)"
    echo ""
    echo -n "  > "
    stty echo 2>/dev/null || true
    read -n 1 -r key 2>/dev/null || true
    echo ""
    case "${key}" in
      r|R) prompt=$(pick_time_prompt "${time_of_day}"); continue ;;
      m|M)
        # Re-select mood for frontmatter — prompt stays time-based
        stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
        echo ""
        echo "  $(t mood_title)"
        echo ""
        mood_menu
        echo ""
        echo -n "  > "
        stty echo 2>/dev/null || true
        read -n 1 -r key 2>/dev/null || key="8"
        echo ""
        mood=$(mood_key_for "${key}")
        prompt=$(pick_time_prompt "${time_of_day}")
        continue 
        ;;
      q|Q|$'\x03'|$'\x04') quit_cleanup; exit 0 ;;
      *) break ;;
    esac
  done

  # Write file with prompt as heading + mood
  {
    echo "---"
    echo "date: ${date_str}"
    echo "mood: ${mood}"
    echo "energy: ${energy}"
    echo "prompt: ${prompt}"
    echo "---"
    echo ""
    echo "${human_date}  ${human_time}"
    echo "--------------------------------"
    echo ""
    echo "# ${prompt}"
    echo ""
  } > "${filepath}"

  stty sane 2>/dev/null || true
  stty echo 2>/dev/null || true
  clear
  # -S = softwrap  -w = nowrap  +9999 = cursor at last line (right under heading)
  nano -S -w +9999 "${filepath}"

  # Process entry in background
  local engine_out
  engine_out=$("${ENGINE}" new "${filepath}" --energy "${energy}" --mood "${mood}" --prompt "${prompt}" 2>/dev/null || true)

  # Auto-link patches via Ollama if enabled
  local linked=0
  local ai_enabled
  ai_enabled=$(get_config "ai_enabled")
  if [[ "${ai_enabled}" == "true" ]] && command -v ollama &>/dev/null; then
    echo "${engine_out}" | python3 -c "
import sys, json, subprocess
d = json.load(sys.stdin)
patches = [m for m in d.get('markers',[]) if m['kind']=='patch']
engine = '${ENGINE}'
for p in patches:
    pid = p.get('id'); ptext = p.get('text','')
    if not pid: continue
    r = subprocess.run([engine,'suggest',ptext], capture_output=True, text=True, timeout=15)
    if r.returncode != 0: continue
    try:
        sug = json.loads(r.stdout)
        if sug.get('id'):
            subprocess.run([engine,'link',str(pid),str(sug['id'])], capture_output=True, timeout=5)
    except: pass
" 2>/dev/null || true
    # Count linked patches for this entry from DB
    linked=$(
      sqlite3 "${DB}" "
        SELECT COUNT(*) FROM bridges b
        JOIN markers m ON b.patch_id = m.id
        WHERE m.entry_id = (SELECT id FROM entries WHERE file_path = '${filepath//\'/''}')
      " 2>/dev/null || echo "0"
    )
  fi

  # Sync if configured
  local couch_url
  couch_url=$(get_config "couch_url")
  if [[ -n "${couch_url}" ]]; then
    export DOJO_COUCH_URL="${couch_url}"
    "${ENGINE}" sync 2>&1 || true
  fi

  # ── Post-save insight ──────────────────────────────────────────────
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  ᗢ"
  echo ""
  echo "  $(pick_var "$(t saved_1)" "$(t saved_2)" "$(t saved_3)")  ·  ${mood}  ·  energy ${energy}/10"
  echo ""

  # Show weakness/patch summary
  local wcount pcount linked_text
  wcount=$(echo "${engine_out}" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len([m for m in d.get('markers',[]) if m['kind']=='weakness']))" 2>/dev/null || echo "0")
  pcount=$(echo "${engine_out}" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len([m for m in d.get('markers',[]) if m['kind']=='patch']))" 2>/dev/null || echo "0")

  if [ "${wcount}" -gt 0 ] || [ "${pcount}" -gt 0 ]; then
    if [ "${wcount}" -gt 0 ]; then
      echo "  Weaknesses tagged: ${wcount}"
      # Show history for each weakness
      local ws_text
      ws_text=$(echo "${engine_out}" | python3 -c "
import sys,json,subprocess
d=json.load(sys.stdin)
ws=[m['text'] for m in d.get('markers',[]) if m['kind']=='weakness']
for w in ws: print(w)" 2>/dev/null || true)
      while IFS= read -r wname; do
        [[ -z "${wname}" ]] && continue
        local w_hist
        w_hist=$(sqlite3 "${DB}" "SELECT COUNT(*) FROM markers WHERE text='${wname}' AND kind='weakness'" 2>/dev/null || echo "?")
        echo "    · ${wname}  (${w_hist}x total)"
      done <<< "${ws_text}"
    fi
    if [ "${pcount}" -gt 0 ]; then
      echo "  Patches found: ${pcount}"
      local ps_text
      ps_text=$(echo "${engine_out}" | python3 -c "
import sys,json
d=json.load(sys.stdin)
ps=[m['text'] for m in d.get('markers',[]) if m['kind']=='patch']
for p in ps: print(p)" 2>/dev/null || true)
      while IFS= read -r pname; do
        [[ -z "${pname}" ]] && continue
        echo "    + ${pname}"
      done <<< "${ps_text}"
    fi
    if [ "${linked}" -gt 0 ]; then
      local linked_label; linked_label=$(t log_linked)
      echo "  ${linked_label//\{count\}/${linked}}"
    fi
  else
    echo "  $(t log_no_tags)"
  fi

  press_enter
  cmd_menu
}

