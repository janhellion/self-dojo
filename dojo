cmd_new() {
  local date_str human_date human_time filepath slug prompt key mood
  date_str=$(date +%Y-%m-%d)
  human_date=$(date +"%A, %B %d, %Y")
  human_time=$(date +"%H:%M")
  slug="${date_str}_$(date +%H%M)"
  filepath="${ENTRIES_DIR}/${slug}.md"
  local c=1
  while [[ -f "${filepath}" ]]; do
    filepath="${ENTRIES_DIR}/${slug}_${c}.md"; c=$((c + 1))
  done

  # ── Mood selection ──────────────────────────────────────────────────
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  $(t mood_title)"
  echo ""
  echo "  [1] ${MOOD_CATEGORIES[0]}    [2] ${MOOD_CATEGORIES[1]}"
  echo "  [3] ${MOOD_CATEGORIES[2]}  [4] ${MOOD_CATEGORIES[3]}"
  echo "  [5] ${MOOD_CATEGORIES[4]}  [6] ${MOOD_CATEGORIES[5]}"
  echo "  [7] ${MOOD_CATEGORIES[6]}  [8] ${MOOD_CATEGORIES[7]}"
  echo ""
  echo -n "  > "
  stty echo 2>/dev/null || true
  read -n 1 -r key 2>/dev/null || key="8"
  echo ""
  mood=$(mood_key_for "${key}")

  prompt=$(pick_mood_prompt "${mood}")

  # ── Prompt screen — show it, let user roll or accept ───────────────
  while true; do
    stty sane 2>/dev/null || true
    stty echo 2>/dev/null || true
    clear
    echo ""
    echo "  ᗢ"
    echo ""
    echo "  ${DIM}${human_date}  ${human_time}${RESET}"
    echo ""
    echo "  ${prompt}"
    echo ""
    echo "  ${DIM}$(t tag_title)${RESET}"
    echo "  ${DIM}$(t tag_stuck)${RESET}"
    echo "  ${DIM}$(t tag_helped)${RESET}"
    echo ""
    echo "  $(t prompt_write_hint)    $(t prompt_roll)    $(t prompt_mood)"
    echo ""
    echo -n "  > "
    stty echo 2>/dev/null || true
    read -n 1 -r key 2>/dev/null || true
    echo ""
    case "${key}" in
      r|R) prompt=$(pick_mood_prompt "${mood}"); continue ;;
      m|M) 
        # Back to mood selection
        stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
        echo ""
        echo "  $(t mood_title)"
        echo ""
        echo "  [1] ${MOOD_CATEGORIES[0]}    [2] ${MOOD_CATEGORIES[1]}"
        echo "  [3] ${MOOD_CATEGORIES[2]}  [4] ${MOOD_CATEGORIES[3]}"
        echo "  [5] ${MOOD_CATEGORIES[4]}  [6] ${MOOD_CATEGORIES[5]}"
        echo "  [7] ${MOOD_CATEGORIES[6]}  [8] ${MOOD_CATEGORIES[7]}"
        echo ""
        echo -n "  > "
        stty echo 2>/dev/null || true
        read -n 1 -r key 2>/dev/null || key="8"
        echo ""
        mood=$(mood_key_for "${key}")
        prompt=$(pick_mood_prompt "${mood}")
        continue 
        ;;
      q|Q|$'\x03'|$'\x04') quit_cleanup; exit 0 ;;
      *) break ;;
    esac
  done

  # Write file with prompt as heading + mood
  {
    echo "---"
    echo "date: ${date_str}"
    echo "mood: ${mood}"
    echo "prompt: ${prompt}"
    echo "---"
    echo ""
    echo "${human_date}  ${human_time}"
    echo "--------------------------------"
    echo ""
    echo "# ${prompt}"
    echo ""
  } > "${filepath}"

  stty sane 2>/dev/null || true
  stty echo 2>/dev/null || true
  clear
  # -S = softwrap  -w = nowrap  +9999 = cursor at last line (right under heading)
  nano -S -w +9999 "${filepath}"

  # Process entry in background
  local engine_out
  engine_out=$("${ENGINE}" new "${filepath}" 2>/dev/null || true)

  # Auto-link patches via Ollama if enabled
  local ai_enabled
  ai_enabled=$(get_config "ai_enabled")
  if [[ "${ai_enabled}" == "true" ]] && command -v ollama &>/dev/null; then
    echo "${engine_out}" | python3 -c "
import sys, json, subprocess
d = json.load(sys.stdin)
patches = [m for m in d.get('markers',[]) if m['kind']=='patch']
engine = '${ENGINE}'
for p in patches:
    pid = p.get('id'); ptext = p.get('text','')
    if not pid: continue
    r = subprocess.run([engine,'suggest',ptext], capture_output=True, text=True, timeout=15)
    if r.returncode != 0: continue
    try:
        sug = json.loads(r.stdout)
        if sug.get('id'):
            subprocess.run([engine,'link',str(pid),str(sug['id'])], capture_output=True, timeout=5)
    except: pass
" 2>/dev/null || true
  fi

  # Sync if configured
  local couch_url
  couch_url=$(get_config "couch_url")
  if [[ -n "${couch_url}" ]]; then
    export DOJO_COUCH_URL="${couch_url}"
    "${ENGINE}" sync &>/dev/null || true
  fi

  # Brief confirmation
  stty sane 2>/dev/null || true
  stty echo 2>/dev/null || true
  clear
  echo ""
  echo "  ᗢ"
  echo ""
  echo "  $(pick_var "$(t saved_1)" "$(t saved_2)" "$(t saved_3)")"
  press_enter
  cmd_menu
}

# ═══════════════════════════════════════════════════════════════════════
# VIEWS
# ═══════════════════════════════════════════════════════════════════════

cmd_log() {
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  local log_output
  log_output=$("${ENGINE}" log 2>/dev/null || echo "NO_ENTRIES")
  echo ""

  if [[ "${log_output}" == "NO_ENTRIES" ]]; then
    echo "  $(t log_nothing)"
    echo ""
    press_enter; return
  fi

  echo "  ᗢ"
  echo ""
  echo "  $(t log_title)"
  echo "  ${DIM}${_box_dots}${RESET}"
  echo ""

  local in_date=false
  while IFS= read -r line; do
    if [[ "${line}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
      ${in_date} && echo ""
      echo "  ${line}"
      in_date=true
    elif [[ -n "${line}" ]]; then
      echo "    ${line}"
    fi
  done <<< "${log_output}"

  echo ""
  echo "  ${DIM}${_box_dots}${RESET}"
  echo ""
  press_enter
}

cmd_deck() {
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  local stats
  stats=$("${ENGINE}" deck 2>/dev/null || echo '{}')
  echo ""
  echo "  ᗢ"
  echo ""

  # Parse stats — output just values, labels done in bash
  local entries avge high low ws_text
  entries=$(echo "${stats}" | python3 -c "import sys,json; print(json.load(sys.stdin).get('total_entries',0))" 2>/dev/null || echo "0")
  avge=$(echo "${stats}" | python3 -c "import sys,json; print(json.load(sys.stdin).get('avg_energy','0.0'))" 2>/dev/null || echo "0.0")
  high=$(echo "${stats}" | python3 -c "import sys,json; print(json.load(sys.stdin).get('high_ratio','0/0'))" 2>/dev/null || echo "0/0")
  low=$(echo "${stats}" | python3 -c "import sys,json; print(json.load(sys.stdin).get('low_ratio','0/0'))" 2>/dev/null || echo "0/0")
  ws_text=$(echo "${stats}" | python3 -c "
import sys, json
d = json.load(sys.stdin)
ws = d.get('top_weaknesses', [])
if ws:
    for w in ws[:5]:
        print(f'{w[\"text\"]}|{w[\"count\"]}')
" 2>/dev/null || true)

  echo "  $(t deck_entries):    ${entries}"
  echo "  $(t deck_avg_energy): ${avge}/10"
  echo "  $(t deck_high): ${high}"
  echo "  $(t deck_low):  ${low}"

  if [[ -n "${ws_text}" ]]; then
    echo ""
    echo "  $(t deck_patched):"
    while IFS='|' read -r wtext wcount; do
      [[ -n "${wtext}" ]] && echo "    · ${wtext}  (${wcount}x)"
    done <<< "${ws_text}"
  elif [[ "${entries}" == "0" ]]; then
    echo ""
    echo "  $(t deck_no_data)"
  fi
  echo ""
  press_enter
}

cmd_check() {
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  ᗢ"
  echo ""
  echo "  $(t check_title)"
  echo "  ${DIM}${_box_dots}${RESET}"
  echo ""

  local engine_check olla couch entry_count models
  export DOJO_COUCH_URL="$(get_config couch_url || true)"
  engine_check=$("${ENGINE}" check 2>/dev/null || echo '{"ollama":false,"couchdb":false,"models":[]}')
  olla=$(echo "${engine_check}" | python3 -c "import sys,json; print('true' if json.load(sys.stdin).get('ollama') else 'false')" 2>/dev/null || echo "false")
  couch=$(echo "${engine_check}" | python3 -c "import sys,json; print('true' if json.load(sys.stdin).get('couchdb') else 'false')" 2>/dev/null || echo "false")
  entry_count=$("${ENGINE}" deck 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('total_entries',0))" 2>/dev/null || echo "0")
  models=$(echo "${engine_check}" | python3 -c "import sys,json; [print(f'    · {m}') for m in json.load(sys.stdin).get('models',[])]" 2>/dev/null || true)

  # Translate status values
  local olla_label couch_label
  [[ "${olla}" == "true" ]] && olla_label="$(t check_connected)" || olla_label="$(t check_offline)"
  [[ "${couch}" == "true" ]] && couch_label="$(t check_connected)" || couch_label="$(t check_offline)"

  echo "  $(t check_engine):      $(t check_built)"
  echo "  $(t check_ollama):      ${olla_label}"
  echo "  $(t check_couchdb):     ${couch_label}"
  echo "  $(t check_entries):     ${entry_count}"
  [[ -n "${models}" ]] && echo "" && echo "  $(t check_models):" && echo "${models}"
  echo ""
  echo "  ${DIM}${_box_dots}${RESET}"
  echo ""
  press_enter
}

# ═══════════════════════════════════════════════════════════════════════
# SETTINGS
# ═══════════════════════════════════════════════════════════════════════

cmd_settings() {
  while true; do
    stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
    local name ai couch key
    name=$(get_config "name"); [[ -z "${name}" ]] && name="$(t label_not_set)"
    ai=$(get_config "ai_enabled")
    # Translate AI status to display label
    [[ "${ai}" == "true" ]] && ai="$(t label_enabled)" || ai="$(t label_disabled)"
    couch=$(get_config "couch_url"); [[ -z "${couch}" ]] && couch="$(t label_not_set)"

    echo ""
    echo "  ᗢ"
    echo ""
    echo "  $(t settings_title)"
    echo "  ${DIM}${_box_dots}${RESET}"
    echo ""
    echo "  [n] $(t settings_name):     ${name}"
    echo "  [a] $(t settings_ai):       ${ai}"
    echo "  [c] $(t settings_sync):     ${couch}"
    echo "  [l] Lang:     ${LANG}"
    echo ""
    echo "  [b] $(t settings_back)"
    echo ""
    echo -n "  > "
    stty echo 2>/dev/null || true
    read -n 1 -r key 2>/dev/null || key="b"
    echo ""

    case "${key}" in
      n|N)
        stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
        echo ""
        echo "  $(t settings_name_prompt)"
        echo ""
        echo -n "  > "
        stty echo 2>/dev/null || true
        local new_name
        read -e -r new_name 2>/dev/null || true
        [[ -n "${new_name}" ]] && set_config "name" "${new_name}"
        ;;
      a|A)
        local current
        current=$(get_config "ai_enabled")
        if [[ "${current}" == "true" ]]; then
          set_config "ai_enabled" "false"
        else
          set_config "ai_enabled" "true"
        fi
        ;;
      c|C)
        stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
        echo ""
        echo "  $(t settings_sync_prompt)"
        echo "  $(t settings_sync_format)"
        echo ""
        echo -n "  > "
        stty echo 2>/dev/null || true
        local url
        read -e -r url 2>/dev/null || true
        set_config "couch_url" "${url}"
        # Test connection if URL was entered
        if [[ -n "${url}" ]]; then
          echo ""
          if curl -s --max-time 3 "${url}" >/dev/null 2>&1; then
            echo "  $(t check_connected | sed 's/./\u&/')"
          else
            echo "  No se pudo conectar a ${url}"
          fi
          press_enter
        fi
        ;;
      l|L)
        [[ "${LANG}" == "en" ]] && LANG="es" || LANG="en"
        set_config "lang" "${LANG}"
        ;;
      b|B|$'\x1b') cmd_menu; return ;;
      q|Q|$'\x03'|$'\x04') quit_cleanup; exit 0 ;;
    esac
  done
}

# ═══════════════════════════════════════════════════════════════════════
# WELCOME MENU — plain read, no gum, no terminal state games
# ═══════════════════════════════════════════════════════════════════════

cmd_menu() {
  stty sane 2>/dev/null || true
  stty echo 2>/dev/null || true
  clear

  local name greeting hour key
  name=$(get_config "name"); [[ -z "${name}" ]] && name="you"

  hour=$(date +%H)
  if [ "${hour}" -lt 12 ]; then
    greeting=$(_t greeting_morning)
  elif [ "${hour}" -lt 18 ]; then
    greeting=$(_t greeting_afternoon)
  else
    greeting=$(_t greeting_evening)
  fi

  echo ""
  echo "  ᗢ"
  echo ""
  echo "  ${greeting}"
  echo ""
  echo "  [w] $(t menu_write)    [t] $(t menu_timeline)    [p] $(t menu_patterns)"
  echo "  [c] $(t menu_check)    [s] $(t menu_settings)    [q] $(t menu_leave)"
  echo ""
  echo -n "  > "

  stty echo 2>/dev/null || true
  read -n 1 -r key 2>/dev/null || { cmd_menu; return; }
  echo ""

  case "${key}" in
    w|W) cmd_new ;;
    e|E) cmd_new ;;  # Spanish alias
    t|T) cmd_log;  cmd_menu ;;
    p|P) cmd_deck; cmd_menu ;;
    c|C) cmd_check; cmd_menu ;;
    s|S) cmd_settings; cmd_menu ;;
    q|Q|$'\x03'|$'\x04') quit_cleanup; exit 0 ;;
    *)   cmd_menu ;;  # any other key → redraw
  esac
}

# ═══════════════════════════════════════════════════════════════════════
# FIRST RUN
# ═══════════════════════════════════════════════════════════════════════

first_run() {
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  ᗢ"
  echo ""
  echo "  ${DIM}self-dojo${RESET}"
  echo ""
  echo -n "  $(t first_name)  > "
  stty echo 2>/dev/null || true
  local new_name
  read -e -r new_name 2>/dev/null || true
  [[ -z "${new_name}" || "${new_name}" == "q" ]] && new_name="you"
  set_config "name" "${new_name}"

  # PIN setup — loop until match or skip
  local p1 p2
  while true; do
    stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
    echo ""
    echo "  $(t first_pin_title)"
    echo "  $(t first_pin_hint)"
    echo ""
    echo -n "  $(t first_pin_prompt) "
    stty -echo 2>/dev/null || true
    read -r p1 2>/dev/null || true
    stty echo 2>/dev/null || true
    echo ""

    [[ -z "${p1}" ]] && break  # skip PIN

    echo -n "  $(t first_pin_confirm) "
    stty -echo 2>/dev/null || true
    read -r p2 2>/dev/null || true
    stty echo 2>/dev/null || true
    echo ""

    if [[ "${p1}" == "${p2}" ]]; then
      set_config "pin_hash" "$(pin_hash "${p1}")"
      PIN="${p1}"
      db_encrypt
      break
    else
      echo "  $(t first_pin_mismatch)"
      echo ""
      press_enter
    fi
  done

  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  if command -v ollama &>/dev/null && curl -s --max-time 2 http://localhost:11434/api/tags >/dev/null 2>&1; then
    echo ""
    echo "  $(t first_ai_detect)"
    echo "    $(t first_ai_hint)"
    echo ""
    echo -n "  [y] $(t label_enabled | sed 's/./\u&/')    [n] $(t label_disabled | sed 's/./\u&/')  > "
    stty echo 2>/dev/null || true
    read -n 1 -r key 2>/dev/null || key="n"
    echo ""
    if [[ "${key}" == "y" || "${key}" == "Y" ]]; then
      set_config "ai_enabled" "true"
    else
      set_config "ai_enabled" "false"
    fi
  else
    set_config "ai_enabled" "false"
  fi
  set_config "couch_url" ""

  # Language selection
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  Language / Idioma"
  echo ""
  echo "  [1] English    [2] Español"
  echo ""
  echo -n "  > "
  stty echo 2>/dev/null || true
  local lang_key
  read -n 1 -r lang_key 2>/dev/null || lang_key="1"
  echo ""
  [[ "${lang_key}" == "2" ]] && LANG="es" || LANG="en"
  set_config "lang" "${LANG}"
  echo ""
  echo "  $(t first_ready)"
  press_enter
}

# ═══════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════

main() {
  # PIN gate — prompt and decrypt before anything else
  if [[ -f "${CONFIG}" ]] && [[ -n "$(get_config pin_hash)" ]]; then
    pin_prompt
    pin_verify
    db_decrypt
  fi

  case "${1:-}" in
    log)    cmd_log ;;
    deck)   cmd_deck ;;
    check)  cmd_check ;;
    help|--help|-h)
      echo "$(t help_text)"
      echo ""
      echo "  $(t help_usage)"
      echo "  $(t help_log)"
      echo "  $(t help_deck)"
      echo "  $(t help_check)"
      ;;
    *)
      [[ ! -f "${CONFIG}" ]] && first_run
      cmd_menu
      ;;
  esac
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
