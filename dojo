# ── Security: DB encryption via openssl aes-256-cbc ───────────────────
db_decrypt() {
  [[ ! -f "${DB_ENC}" ]] && return 0
  openssl enc -d -aes-256-cbc -pbkdf2 -iter 100000 -pass pass:"${PIN}" \
    -in "${DB_ENC}" -out "${DB}" 2>/dev/null || {
    echo ""; echo "  $(t pin_wrong)"; echo ""; exit 1
  }
}

db_encrypt() {
  [[ ! -f "${DB}" ]] && return 0
  openssl enc -aes-256-cbc -pbkdf2 -iter 100000 -pass pass:"${PIN}" \
    -in "${DB}" -out "${DB_ENC}" 2>/dev/null || true
  shred -u "${DB}" 2>/dev/null || rm -f "${DB}"
}

pin_hash() { echo -n "$1" | sha256sum | cut -d' ' -f1; }

pin_prompt() {
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  ᗢ"
  echo ""
  echo -n "  PIN: "
  stty -echo 2>/dev/null || true
  read -r PIN 2>/dev/null || true
  stty echo 2>/dev/null || true
  echo ""
  [[ -z "${PIN}" ]] && { echo "  $(t pin_required)"; exit 1; }
  return 0
}

pin_verify() {
  local stored
  stored=$(get_config "pin_hash")
  [[ -z "${stored}" ]] && return 0  # no PIN set yet
  [[ "$(pin_hash "${PIN}")" != "${stored}" ]] && {
    echo ""; echo "  $(t pin_wrong)"; echo ""; exit 1
  }
  return 0
}

# ── Terminal safety — echo before EVERY user input ────────────────────
_echo_on() { stty echo 2>/dev/null || true; }

quit_cleanup() {
  _echo_on
  db_encrypt   # encrypt before exit
  echo ""
  echo "  ·  $(t quit_text)  ·"
  echo ""
}
trap 'quit_cleanup; exit 0' SIGINT SIGTERM SIGQUIT

