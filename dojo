# ── Spanish time-of-day pools ──────────────────────────────────────────

TIME_PROMPTS_MORNING_ES="¿Qué quiero sentir hoy?|¿Qué una cosa quiero proteger hoy?|¿Qué tipo de transición necesito para empezar el día?|¿Con qué nivel de energía empiezo y qué significa eso?|¿Qué preparación sensorial me ayudaría hoy?|¿Qué es lo único que haría que hoy se sienta bien?|¿Ya estoy planeando demasiado?|¿Qué puedo quitar de hoy antes de que empiece?"

TIME_PROMPTS_AFTERNOON_ES="¿Cómo ha cambiado mi energía desde esta mañana?|¿Qué he logrado hasta ahora, sin importar qué tan pequeño?|¿Qué necesito ahora mismo para seguir?|¿Qué me robó la atención y valió la pena seguirlo?|¿Tengo hambre, cansancio o sobreestimulación?|¿Qué puedo soltar del resto del día?|¿Qué límite necesito poner para la tarde?|¿Qué sería un buen reinicio ahora?"

TIME_PROMPTS_EVENING_ES="¿Qué salió mejor de lo esperado hoy?|¿Qué es una cosa que puedo soltar antes de dormir?|¿Qué aprendí sobre mí mismo hoy?|¿Qué cargo hoy que puedo dejar ir?|¿Qué entrada sensorial necesito para desconectar?|¿Qué pequeña victoria merece reconocimiento?|¿Qué haría que mañana en la mañana sea más fácil?|¿Me encontré a mí mismo donde estaba hoy?"

# Detect time of day (morning/afternoon/evening)
detect_time_of_day() {
  local h
  h=$(date +%H)
  # Strip leading zero
  h=$((10#$h))
  if [ "$h" -lt 12 ]; then
    echo "morning"
  elif [ "$h" -lt 18 ]; then
    echo "afternoon"
  else
    echo "evening"
  fi
}

# Pick a random prompt from a time-of-day pool
pick_time_prompt() {
  local tod="${1:-morning}"
  local pool
  if [[ "${LANG}" == "es" ]]; then
    case "${tod}" in
      morning)   pool="${TIME_PROMPTS_MORNING_ES}" ;;
      afternoon) pool="${TIME_PROMPTS_AFTERNOON_ES}" ;;
      evening)   pool="${TIME_PROMPTS_EVENING_ES}" ;;
      *)         pool="${TIME_PROMPTS_MORNING_ES}" ;;
    esac
  else
    case "${tod}" in
      morning)   pool="${TIME_PROMPTS_MORNING}" ;;
      afternoon) pool="${TIME_PROMPTS_AFTERNOON}" ;;
      evening)   pool="${TIME_PROMPTS_EVENING}" ;;
      *)         pool="${TIME_PROMPTS_MORNING}" ;;
    esac
  fi
  local IFS='|'; local prompts=($pool)
  echo "${prompts[$((RANDOM % ${#prompts[@]}))]}"
}

# Pick mood key from selection index (1-8)
mood_key_for() {
  case "$1" in
    1) echo "tired" ;;      2) echo "calm" ;;
    3) echo "focused" ;;    4) echo "scattered" ;;
    5) echo "energetic" ;;  6) echo "frustrated" ;;
    7) echo "reflective" ;; 8) echo "neutral" ;;
    *) echo "neutral" ;;
  esac
}

# Pick a random prompt from a mood category
pick_mood_prompt() {
  local mood="${1:-neutral}"
  local pool
  if [[ "${LANG}" == "es" ]]; then
    pool="${MOOD_PROMPTS_ES[$mood]:-${MOOD_PROMPTS_ES["neutral"]}}"
  else
    pool="${MOOD_PROMPTS[$mood]:-${MOOD_PROMPTS["neutral"]}}"
  fi
  local IFS='|'; local prompts=($pool)
  echo "${prompts[$((RANDOM % ${#prompts[@]}))]}"
}

