# ── Box drawing ───────────────────────────────────────────────────────
detect_cols() {
  SCREEN_COLS=$(tput cols 2>/dev/null || echo 80)
  BOX_INNER=$(( SCREEN_COLS < 60 ? 42 : SCREEN_COLS - 10 ))
  [[ ${BOX_INNER} -gt 100 ]] && BOX_INNER=100
  _box_dots=""; for ((i=0; i<BOX_INNER+4; i++)); do _box_dots+="·"; done
}
detect_cols
box_top()   { echo "  ${DIM}${_box_dots}${RESET}"; }
box_bot()   { echo "  ${DIM}${_box_dots}${RESET}"; }
pick_var()  { local arr=("$@"); echo "${arr[$((RANDOM % ${#arr[@]}))]}"; }

press_enter() {
  echo ""; echo -n "  ${DIM}▸  Press Enter${RESET} "
  stty echo 2>/dev/null || true
  read -r 2>/dev/null || true  # NOT silent — user can see their keystroke
  echo ""
}

# ── Mood & Prompt library ──────────────────────────────────────────────
# Based on: Plutchik's circumplex (activation × valence), AuDHD sensory
# states, and the principle of descriptive-not-evaluative labeling.
#
#   Activation axis:  low ← → high
#   Valence axis:     negative ← → positive
#
# Quadrants:
#   high+positive: focused, energetic, curious
#   high+negative: scattered, frustrated, overstimulated
#   low+positive:  calm, reflective, grounded
#   low+negative:  tired, low, foggy
#   center:        neutral, present, okay

MOOD_CATEGORIES=(
  "(._.) $(t mood_tired)"         # 1 — low activation, negative valence (droopy)
  "(^_^) $(t mood_calm)"          # 2 — low activation, positive valence (content)
  "(ò_ó) $(t mood_focused)"       # 3 — high activation, positive valence (intense)
  "(@_@) $(t mood_scattered)"     # 4 — high activation, negative valence (dizzy)
  "(*_*) $(t mood_energetic)"     # 5 — high activation, positive valence (starry)
  "(>_<) $(t mood_frustrated)"    # 6 — high activation, negative valence (pained)
  "(o_o) $(t mood_reflective)"    # 7 — low-mid activation, positive valence (wide-eyed)
  "(-_-) $(t mood_neutral)"       # 8 — center, unmarked (flat)
)

# Prompt pools — each mood gets 4 prompts matched to that state
declare -A MOOD_PROMPTS

# tired (low-/neg): prompts about rest, avoidance, boundaries
