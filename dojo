# FIRST RUN
# ═══════════════════════════════════════════════════════════════════════

first_run() {
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  ᗢ"
  echo ""
  echo "  ${DIM}self-dojo${RESET}"
  echo ""
  echo -n "  $(t first_name)  > "
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true
  local new_name
  read -r new_name 2>/dev/null || true
  [[ -z "${new_name}" || "${new_name}" == "q" ]] && new_name="you"
  set_config "name" "${new_name}"

  # PIN setup — loop until match or skip
  local p1 p2
  while true; do
    stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
    echo ""
    echo "  $(t first_pin_title)"
    echo "  $(t first_pin_hint)"
    echo ""
    echo -n "  $(t first_pin_prompt) "
    stty -echo 2>/dev/null || true
    read -r p1 2>/dev/null || true
    stty echo 2>/dev/null || true
    echo ""

    [[ -z "${p1}" ]] && break  # skip PIN

    echo -n "  $(t first_pin_confirm) "
    stty -echo 2>/dev/null || true
    read -r p2 2>/dev/null || true
    stty echo 2>/dev/null || true
    echo ""

    if [[ "${p1}" == "${p2}" ]]; then
      set_config "pin_hash" "$(pin_hash "${p1}")"
      PIN="${p1}"
      db_encrypt
      break
    else
      echo "  $(t first_pin_mismatch)"
      echo ""
      press_enter
    fi
  done

  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  if command -v ollama &>/dev/null && curl -s --max-time 2 http://localhost:11434/api/tags >/dev/null 2>&1; then
    echo ""
    echo "  $(t first_ai_detect)"
    echo "    $(t first_ai_hint)"
    echo ""
    echo -n "  [y] $(t label_enabled | sed 's/./\u&/')    [n] $(t label_disabled | sed 's/./\u&/')  > "
    stty echo 2>/dev/null || true
    read -n 1 -r key 2>/dev/null || key="n"
    echo ""
    if [[ "${key}" == "y" || "${key}" == "Y" ]]; then
      set_config "ai_enabled" "true"
    else
      set_config "ai_enabled" "false"
    fi
  else
    set_config "ai_enabled" "false"
  fi
  set_config "couch_url" ""

  # Language selection
  stty sane 2>/dev/null || true; stty echo 2>/dev/null || true; clear
  echo ""
  echo "  Language / Idioma"
  echo ""
  echo "  [1] English    [2] Español"
  echo ""
  echo -n "  > "
  stty echo 2>/dev/null || true
  local lang_key
  read -n 1 -r lang_key 2>/dev/null || lang_key="1"
  echo ""
  [[ "${lang_key}" == "2" ]] && LANG="es" || LANG="en"
  set_config "lang" "${LANG}"
  echo ""
  echo "  $(t first_ready)"
  press_enter
}

# ═══════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════

main() {
  # PIN gate — prompt and decrypt before anything else
  if [[ -f "${CONFIG}" ]] && [[ -n "$(get_config pin_hash)" ]]; then
    pin_prompt
    pin_verify
    db_decrypt
  fi

  # Pull remote entries on startup
  local sync_url
  sync_url=$(get_config "couch_url")
  if [[ -n "${sync_url}" ]]; then
    export DOJO_COUCH_URL="${sync_url}"
    "${ENGINE}" pull 2>&1 || true
  fi

  case "${1:-}" in
    log)    cmd_log ;;
    deck)   cmd_deck ;;
    check)  cmd_check ;;
    help|--help|-h)
      echo "$(t help_text)"
      echo ""
      echo "  $(t help_usage)"
      echo "  $(t help_log)"
      echo "  $(t help_deck)"
      echo "  $(t help_check)"
      ;;
    *)
      [[ ! -f "${CONFIG}" ]] && first_run
      cmd_menu
      ;;
  esac
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
