# Replace {name} placeholder in translation output
_t() {
  local name result
  name=$(get_config "name"); [[ -z "${name}" ]] && name="you"
  result=$(t "$@")
  echo "${result//\{name\}/${name}}"
}

# ── Config ────────────────────────────────────────────────────────────
get_config() { grep -E "^${1}=" "${CONFIG}" 2>/dev/null | cut -d'=' -f2- | head -1 || true; }
set_config() {
  if grep -qE "^${1}=" "${CONFIG}" 2>/dev/null; then
    sed -i "s|^${1}=.*|${1}=${2}|" "${CONFIG}"
  else echo "${1}=${2}" >> "${CONFIG}"; fi
}
